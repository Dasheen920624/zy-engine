  "items": [
    {
      "case_id": "CASE_EMR_MISS_001",
      "patient_context": {
        "patient": {"patient_id": "P_EMR_M01"},
        "encounter": {"encounter_id": "E_EMR_M01"},
        "facts": {
          "emr": {
            "discharge_summary": {
              "chief_complaint_filled": false,
              "diagnosis_filled": true,
              "discharge_orders_filled": true
            }
          }
        }
      }
    },
    {
      "case_id": "CASE_EMR_PASS_002",
      "patient_context": {
        "patient": {"patient_id": "P_EMR_M02"},
        "encounter": {"encounter_id": "E_EMR_M02"},
        "facts": {
          "emr": {
            "discharge_summary": {
              "chief_complaint_filled": true,
              "diagnosis_filled": true,
              "discharge_orders_filled": true
            }
          }
        }
