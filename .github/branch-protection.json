{
  "rules": [
    {
      "pattern": "main",
      "protection": {
        "allowed_merge_targets": ["develop"],
        "required_pull_request_reviews": {
          "dismiss_stale_reviews": true,
          "require_code_owner_reviews": true,
          "required_approving_review_count": 2
        },
        "required_status_checks": {
          "strict": true,
          "contexts": [
            "backend-build-test",
            "frontend-build-test",
            "guard-rules",
            "ai-collaboration-guard"
          ]
        },
        "enforce_admins": true,
        "restrictions": null,
        "description": "main 分支为发布分支，仅接受来自 develop 的 PR；禁止直接 push；至少 2 人审核；CI 全绿方可合并"
      }
    },
    {
      "pattern": "develop",
      "protection": {
        "allowed_merge_targets": [],
        "required_pull_request_reviews": {
          "dismiss_stale_reviews": true,
          "require_code_owner_reviews": false,
          "required_approving_review_count": 1
        },
        "required_status_checks": {
          "strict": false,
          "contexts": [
            "backend-build-test",
            "frontend-build-test",
            "guard-rules",
            "ai-collaboration-guard"
          ]
        },
        "enforce_admins": false,
        "restrictions": null,
        "description": "develop 为集成分支，AI 任务分支和 feature 分支合并到此；至少 1 人审核；CI 全绿方可合并"
      }
    }
  ],
  "tag_rules": {
    "pattern": "v[0-9]+.[0-9]+.[0-9]+*",
    "must_be_on_branch": "main",
    "semver_required": true,
    "signed_required": false,
    "description": "发布 tag 必须符合 semver 格式，必须基于 main 分支"
  },
  "release_flow": {
    "steps": [
      "1. develop -> main PR（需 2 人审核 + CI 绿）",
      "2. 合并到 main",
      "3. 在 main 上打 v* tag",
      "4. CI 自动触发 release.yml：校验 tag + 生成 manifest + 创建 GitHub Release",
      "5. verify-tag.ps1 本地校验发布完整性"
    ]
  }
}
