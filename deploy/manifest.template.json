{
  "$schema": "https://json.schemastore.org/package",
  "name": "zy-engine",
  "version": "0.0.0",
  "git_hash": "0000000",
  "build_time": "0000-00-00T00:00:00+08:00",
  "build_host": "ci-builder",

  "components": {
    "backend": {
      "jar": "lib/zy-engine.jar",
      "sha256": "TO_BE_FILLED_BY_BUILD_SCRIPT",
      "spring_boot_version": "2.7.18",
      "jdk_target": "1.8"
    },
    "frontend": {
      "dist": "frontend/dist/",
      "sha256": "TO_BE_FILLED_BY_BUILD_SCRIPT",
      "framework": "React 18 + Vite 5 + AntD 5"
    },
    "db_oracle": {
      "ddl": "db/oracle/zyengine_core_ddl_with_comments.sql",
      "migration": "db/oracle/zyengine_org_context_migration.sql",
      "comments": "db/oracle/zyengine_comments_unistr.sql"
    },
    "db_dm": {
      "ddl": "db/dm/zyengine_core_ddl_with_comments.sql",
      "migration": "db/dm/zyengine_org_context_migration.sql"
    },
    "db_postgres": {
      "ddl": "db/postgres/zyengine_core_ddl_with_comments.sql",
      "migration": "db/postgres/zyengine_org_context_migration.sql"
    }
  },

  "supported_os": [
    "centos7-x86_64",
    "openeuler-22.03-x86_64",
    "openeuler-22.03-aarch64",
    "uos-v20-x86_64",
    "uos-v20-aarch64",
    "kylin-v10-x86_64",
    "kylin-v10-aarch64",
    "windows-server-x86_64"
  ],

  "supported_databases": [
    {"name": "Oracle", "versions": ["11g R2", "12c", "18c", "19c", "21c"]},
    {"name": "Dameng DM", "versions": ["DM 7", "DM 8"]},
    {"name": "PostgreSQL", "versions": ["14", "15", "16"]},
    {"name": "KingbaseES", "versions": ["V8 R3", "V8 R6"]}
  ],

  "required_runtime": {
    "jdk": "1.8.0_202+",
    "memory_min_mb": 2048,
    "disk_min_gb": 10,
    "open_ports": [18080],
    "open_ports_frontend": [80, 443]
  },

  "release_notes_file": "CHANGELOG.md",
  "deploy_docs": [
    "docs/部署手册.md",
    "docs/升级手册.md",
    "docs/灾备手册.md"
  ]
}
