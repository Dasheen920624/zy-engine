MEDKERNEL_RUNTIME_ROOT=/Users/zhikunzheng/work/medkernel/runtime

POSTGRES_IMAGE=postgres:16.14-bookworm
MEDKERNEL_DB_NAME=medkernel
MEDKERNEL_DB_USERNAME=medkernel
MEDKERNEL_DB_PASSWORD=__GENERATED_BY_BOOTSTRAP__
MEDKERNEL_POSTGRES_PORT=15432

NEO4J_IMAGE=neo4j:5.23.0-community
