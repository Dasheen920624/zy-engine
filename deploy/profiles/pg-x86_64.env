# 部署 profile：通用 Linux x86_64 + PostgreSQL 16
# 适用：OpenEuler / Rocky / CentOS Stream / Debian / Ubuntu Server

ZY_HOME=/opt/zy-engine
ZY_USER=zyengine
ZY_BACKUP_DIR=/opt/zy-engine.bak

# ---- JDK ----
JAVA_HOME=/usr/lib/jvm/java-1.8.0-openjdk

# ---- HTTP ----
ZYENGINE_HTTP_PORT=18080
ZYENGINE_HTTP_CONTEXT=/zy-engine

# ---- 数据库 ----
ZYENGINE_DB_ENABLED=true
ZYENGINE_DB_DIALECT=postgres
ZYENGINE_DB_HOST=10.0.0.30
ZYENGINE_DB_PORT=5432
ZYENGINE_DB_NAME=zyengine
ZYENGINE_DB_URL=jdbc:postgresql://${ZYENGINE_DB_HOST}:${ZYENGINE_DB_PORT}/${ZYENGINE_DB_NAME}?reWriteBatchedInserts=true&prepareThreshold=0
ZYENGINE_DB_USERNAME=zyengine
ZYENGINE_DB_PASSWORD=__REPLACE_ME__

# ---- 图谱 / Dify ----
ZYENGINE_GRAPH_ENABLED=false
ZYENGINE_DIFY_ENABLED=false

# ---- JVM ----
JAVA_OPTS="-server -Xms2g -Xmx4g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -Dfile.encoding=UTF-8 -Dsun.jnu.encoding=UTF-8 -Duser.timezone=Asia/Shanghai"
