# 部署 profile：CentOS 7 + x86_64 + Oracle
# 用法：cp centos7-x86_64-oracle.env /zoesoft/medkernel/conf/medkernel.env && $EDITOR ...

# ---- 路径 ----
MK_HOME=/zoesoft/medkernel
MK_USER=medkernel
MK_BACKUP_DIR=/zoesoft/medkernel.bak

# ---- JDK ----
JAVA_HOME=/zoesoft/medkernel/jdk
# 或系统已装：JAVA_HOME=/usr/lib/jvm/java-1.8.0-openjdk

# ---- HTTP ----
MEDKERNEL_HTTP_PORT=18080
MEDKERNEL_HTTP_CONTEXT=/medkernel

# ---- 数据库 ----
MEDKERNEL_DB_ENABLED=true
MEDKERNEL_DB_DIALECT=oracle
MEDKERNEL_DB_CONNECT=//10.0.0.10:1521/ORCL
MEDKERNEL_DB_URL=jdbc:oracle:thin:@${MEDKERNEL_DB_CONNECT}
MEDKERNEL_DB_USERNAME=MEDKERNEL
MEDKERNEL_DB_PASSWORD=__REPLACE_ME__

# ---- 图谱 / Dify ----
MEDKERNEL_GRAPH_ENABLED=false
MEDKERNEL_DIFY_ENABLED=false

# ---- JVM ----
JAVA_OPTS="-server -Xms2g -Xmx4g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -Dfile.encoding=UTF-8 -Dsun.jnu.encoding=UTF-8 -Duser.timezone=Asia/Shanghai"

# ---- 安全 ----
# 请确保 600 权限：chmod 600 /zoesoft/medkernel/conf/medkernel.env
