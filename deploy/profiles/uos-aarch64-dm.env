# 部署 profile：统信 UOS V20 + aarch64（鲲鹏/飞腾）+ 达梦 DM 8
# 注意：JDK 必须用 ARM 版（推荐毕昇 JDK 8 鲲鹏优化版）

ZY_HOME=/opt/zy-engine
ZY_USER=zyengine
ZY_BACKUP_DIR=/opt/zy-engine.bak

# ---- JDK ----
JAVA_HOME=/opt/bisheng-jdk1.8.0_402

# ---- HTTP ----
ZYENGINE_HTTP_PORT=18080
ZYENGINE_HTTP_CONTEXT=/zy-engine

# ---- 数据库 ----
ZYENGINE_DB_ENABLED=true
ZYENGINE_DB_DIALECT=dm
ZYENGINE_DB_CONNECT=10.0.0.20:5236
ZYENGINE_DB_URL=jdbc:dm://${ZYENGINE_DB_CONNECT}?clobAsString=true&serverTimezone=Asia/Shanghai
ZYENGINE_DB_USERNAME=ZYENGINE
ZYENGINE_DB_PASSWORD=__REPLACE_ME__

# ---- 图谱 / Dify ----
ZYENGINE_GRAPH_ENABLED=false
ZYENGINE_DIFY_ENABLED=false

# ---- JVM（毕昇 JDK 鲲鹏优化）----
JAVA_OPTS="-server -Xms2g -Xmx4g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -Dfile.encoding=UTF-8 -Dsun.jnu.encoding=UTF-8 -Duser.timezone=Asia/Shanghai"
