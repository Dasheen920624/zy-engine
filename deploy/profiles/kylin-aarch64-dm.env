# 部署 profile：麒麟 Kylin V10 SP3 + aarch64（鲲鹏/飞腾）+ 达梦 DM 8
# 注意：
#   1) JDK 必须用 ARM 版（推荐毕昇 JDK 8 鲲鹏优化版）
#   2) Kylin V10 默认 SELinux Enforcing，install-offline.sh 会自动配置 fcontext
#   3) 部分小版本 OpenSSL 1.0.2 与 JDK 8 SSL 握手敏感，必要时加 -Djdk.tls.client.protocols=TLSv1.2

MK_HOME=/zoesoft/medkernel
MK_USER=medkernel
MK_BACKUP_DIR=/zoesoft/medkernel.bak

# ---- JDK ----
JAVA_HOME=/opt/bisheng-jdk1.8.0_402

# ---- HTTP ----
MEDKERNEL_HTTP_PORT=18080
MEDKERNEL_HTTP_CONTEXT=/medkernel

# ---- 数据库 ----
MEDKERNEL_DB_ENABLED=true
MEDKERNEL_DB_DIALECT=dm
MEDKERNEL_DB_CONNECT=10.0.0.20:5236
MEDKERNEL_DB_URL=jdbc:dm://${MEDKERNEL_DB_CONNECT}?clobAsString=true&serverTimezone=Asia/Shanghai
MEDKERNEL_DB_USERNAME=MEDKERNEL
MEDKERNEL_DB_PASSWORD=__REPLACE_ME__

# ---- 图谱 / Dify ----
MEDKERNEL_GRAPH_ENABLED=false
MEDKERNEL_DIFY_ENABLED=false

# ---- JVM ----
JAVA_OPTS="-server -Xms2g -Xmx4g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -Dfile.encoding=UTF-8 -Dsun.jnu.encoding=UTF-8 -Duser.timezone=Asia/Shanghai -Djdk.tls.client.protocols=TLSv1.2"
