        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"medkernel-mvp\",status=~\"4..\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{application=\"medkernel-mvp\"}[5m])), 0.001)",
