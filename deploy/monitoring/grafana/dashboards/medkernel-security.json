{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "MedKernel 安全管理看板 (GA-OPS-01)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "安全概览",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "title": "认证失败率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"medkernel-mvp\",uri=~\"/api/auth.*\",status=\"401\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{application=\"medkernel-mvp\",uri=~\"/api/auth.*\"}[5m])), 1)",
          "legendFormat": "401 失败率",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "权限拒绝趋势",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"medkernel-mvp\",status=\"403\"}[5m]))",
          "legendFormat": "403 拒绝率",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "数据脱敏状态",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "increase(medkernel_data_masking_total{result=\"failure\"}[1h])",
          "legendFormat": "脱敏失败次数",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "审计日志写入状态",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "increase(medkernel_audit_log_write_total{result=\"failure\"}[1h])",
          "legendFormat": "审计日志失败次数",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "安全告警",
      "type": "alertlist",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 9 },
      "options": {
        "groupMode": "default",
        "groupBy": ["alertname"],
        "showAnnotations": false,
        "sortOrder": 1
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "filters": [
        { "condition": "=", "key": "slo", "value": "" },
        { "condition": "=", "key": "severity", "value": "critical" }
      ]
    },
    {
      "title": "请求状态码分布",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"medkernel-mvp\",status=~\"2..\"}[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"medkernel-mvp\",status=~\"4..\"}[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"medkernel-mvp\",status=~\"5..\"}[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["medkernel", "security", "ga-ops-01"],
  "templating": {
    "list": []
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "MedKernel Security Dashboard",
  "uid": "medkernel-security",
  "version": 1
}
