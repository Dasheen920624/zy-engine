# 前端环境变量样例（Vite 约定：以 VITE_ 前缀的变量会被注入到 import.meta.env）
# 真实 .env 不进 Git，请按本机/部署环境复制本文件为 .env.local 后修改。

# 后端基础地址。开发期可留空走 vite proxy；生产环境填同源相对路径或反代地址。
VITE_API_BASE_URL=

# 默认组织上下文（仅用于本地调试，正式登录后由后端会话决定）
VITE_DEFAULT_TENANT_ID=TENANT_DEMO
VITE_DEFAULT_GROUP_CODE=GROUP_DEMO
VITE_DEFAULT_HOSPITAL_CODE=HOSPITAL_DEMO

# 是否启用 MSW mock（true / false）
VITE_ENABLE_MSW=false
