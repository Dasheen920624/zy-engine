{
  "name": "medkernel-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "医疗智能引擎平台治理控制台前端",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 5173",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\" \"*.{json,md}\"",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run lint && npm run format:check && npm run typecheck && npm test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@ant-design/icons": "5.5.2",
    "@tanstack/react-query": "5.59.0",
    "antd": "5.21.6",
    "axios": "1.7.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.27.0"
  },
  "devDependencies": {
    "@eslint/js": "9.12.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.5.0",
    "@testing-library/react": "16.0.1",
    "@types/node": "22.7.4",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.2",
    "eslint": "9.12.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-react-refresh": "0.4.12",
    "globals": "15.10.0",
    "jsdom": "25.0.1",
    "msw": "2.4.9",
    "prettier": "3.3.3",
    "storybook": "^8.6.18",
    "typescript": "5.6.3",
    "typescript-eslint": "8.8.1",
    "vite": "5.4.8",
    "vitest": "2.1.2"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
