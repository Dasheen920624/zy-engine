{
  "name": "medkernel-frontend",
  "private": true,
  "version": "1.0.0-SNAPSHOT",
  "type": "module",
  "description": "集团医疗智能中枢 MedKernel · v1.0 GA 前端",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 5173",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\" \"*.{json,md}\"",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "gen:types": "openapi-typescript http://localhost:18080/medkernel/v3/api-docs -o src/shared/api/generated-types.ts",
    "verify": "npm run lint && npm run format:check && npm run typecheck && npm test",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report e2e-report"
  },
  "dependencies": {
    "@ant-design/icons": "5.5.2",
    "@tanstack/react-query": "5.59.0",
    "antd": "5.21.6",
    "axios": "1.7.7",
    "i18next": "23.16.0",
    "i18next-browser-languagedetector": "8.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "15.1.0",
    "react-router-dom": "6.27.0",
    "zustand": "5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "9.12.0",
    "@playwright/test": "1.48.0",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.5.0",
    "@testing-library/react": "16.0.1",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "22.7.4",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.2",
    "@vitest/coverage-v8": "2.1.2",
    "eslint": "9.12.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-react-refresh": "0.4.12",
    "globals": "15.10.0",
    "jsdom": "25.0.1",
    "msw": "2.4.9",
    "openapi-typescript": "7.4.4",
    "prettier": "3.3.3",
    "typescript": "5.6.3",
    "typescript-eslint": "8.8.1",
    "vite": "5.4.8",
    "vitest": "2.1.2"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
