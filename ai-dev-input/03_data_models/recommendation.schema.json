{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "recommendation.schema.json",
  "title": "RecommendationCard",
  "type": "object",
  "required": ["recommendation_id", "scenario", "patient_id", "encounter_id", "target_code", "target_name", "score", "confidence", "action_level"],
  "properties": {
    "recommendation_id": {"type": "string"},
    "scenario": {"type": "string", "enum": ["DISEASE_CANDIDATE", "PATHWAY_ENTRY", "TREATMENT_RECOMMEND", "RISK_ALERT", "FOLLOWUP_ALERT"]},
    "patient_id": {"type": "string"},
    "encounter_id": {"type": "string"},
    "target_code": {"type": "string"},
    "target_name": {"type": "string"},
    "score": {"type": "number", "minimum": 0, "maximum": 100},
    "confidence": {"type": "string", "enum": ["HIGH", "MEDIUM", "LOW"]},
    "action_level": {"type": "string", "enum": ["BLOCK", "STRONG_ALERT", "WEAK_ALERT", "INFO"]},
    "supporting_facts": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "opposing_facts": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "missing_facts": {"type": "array", "items": {"type": "string"}},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "suggested_actions": {"type": "array", "items": {"type": "string"}},
    "model_trace": {"type": "object", "additionalProperties": true}
  },
  "additionalProperties": false
}

