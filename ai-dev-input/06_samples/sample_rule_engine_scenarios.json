{
  "package_code": "PKG_RULE_ENGINE_SCENARIOS",
  "package_version": "2026.05",
  "rules": [
    {
      "rule_code": "R_EMR_DISCHARGE_SUMMARY_COMPLETE",
      "rule_name": "出院小结主诉与诊断必须完整",
      "rule_type": "EMR_QC",
      "scenario_codes": ["EMR_QC"],
      "severity": "MEDIUM",
      "priority": 90,
      "enabled": true,
      "description": "病历质控：出院小结必须包含主诉、诊断、出院医嘱三项关键内容，任一缺失即视为质控不通过。",
      "condition": {
        "any": [
          {"fact": "emr.discharge_summary.chief_complaint_filled", "operator": "equals", "value": false},
          {"fact": "emr.discharge_summary.diagnosis_filled", "operator": "equals", "value": false},
          {"fact": "emr.discharge_summary.discharge_orders_filled", "operator": "equals", "value": false}
        ]
      },
      "actions": [
        {"type": "EMR_QC_FAIL"},
        {"type": "PUSH_TO_DOCTOR", "level": "INFO"}
      ],
      "message_template": "出院小结存在必填项缺失，请补全后再次提交。"
    },
    {
      "rule_code": "R_INS_DRUG_INDICATION_MISMATCH",
      "rule_name": "医保限定适应症与诊断不一致",
      "rule_type": "INSURANCE_QC",
      "scenario_codes": ["INSURANCE_QC", "DRUG_INDICATION"],
      "severity": "HIGH",
      "priority": 110,
      "enabled": true,
      "description": "医保质控：医保限定适应症药品必须有匹配诊断，否则不予支付且需要补充指征或更换医嘱。",
      "condition": {
        "all": [
          {"fact": "orders.insurance_restricted_drug_used", "operator": "equals", "value": true},
          {"fact": "orders.insurance_restricted_drug_indication_matched", "operator": "equals", "value": false}
        ]
      },
      "actions": [
        {"type": "INSURANCE_QC_FAIL"},
        {"type": "REQUEST_PRE_AUTH"}
      ],
      "message_template": "存在医保限定适应症与诊断不匹配的药品，建议补充指征或更换医嘱后重新提交。"
    },
    {
      "rule_code": "R_ORDER_SAFETY_DUP_ANTIBIOTIC",
      "rule_name": "重复抗菌药物医嘱拦截",
      "rule_type": "SAFETY_BLOCK",
      "scenario_codes": ["ORDER_SAFETY"],
      "severity": "CRITICAL",
      "priority": 130,
      "enabled": true,
      "description": "医嘱安全：48小时内同一抗菌药物重复开立时进行拦截并要求上级医师确认。",
      "condition": {
        "all": [
          {"fact": "orders.antibiotic_duplicate_within_48h", "operator": "equals", "value": true}
        ]
      },
      "actions": [
        {"type": "BLOCK_ORDER", "order_category": "ANTIBIOTIC"},
        {"type": "PUSH_TO_DOCTOR", "level": "SAFETY_BLOCK"}
      ],
      "message_template": "检测到48小时内重复开立抗菌药物，请由上级医师确认必要性后再下达。"
    }
  ]
}
