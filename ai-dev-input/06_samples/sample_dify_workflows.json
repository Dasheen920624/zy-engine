{
  "templates": [
    {
      "workflow_code": "WF_AMI_ENTRY_EXPLAIN",
      "workflow_name": "AMI入径推荐解释",
      "workflow_version": "1.0.0",
      "description": "在医生工作站显示 AMI/STEMI 候选路径时，调用 Dify 生成结合证据与禁忌证的解释卡。",
      "dify_app_code": "ami-entry-explain",
      "timeout_ms": 5000,
      "retry_count": 1,
      "required_inputs": [
        "patient_id",
        "encounter_id",
        "target_code"
      ],
      "input_mappings": {
        "patient_id": "patient_context.patient.patient_id",
        "encounter_id": "patient_context.encounter.encounter_id",
        "target_code": "recommendation.target_code"
      },
      "input_defaults": {
        "scenario": "PATHWAY_ENTRY",
        "language": "zh-CN",
        "evidence_refs": [
          "EV_AMI_001"
        ]
      },
      "degraded_outputs": {
        "explanation": "Dify 不可用：已基于图谱证据与规则命中给出本地降级解释，请医生结合病历确认。",
        "recommended_action": "保留 AMI/STEMI 路径候选与人工确认，待 Dify 恢复后补充更完整说明。"
      }
    },
    {
      "workflow_code": "WF_AMI_REPERFUSION_HINT",
      "workflow_name": "AMI再灌注策略提示",
      "workflow_version": "1.0.0",
      "description": "再灌注评估节点调用 Dify 生成 PCI vs 溶栓的策略提示，附禁忌证检查。",
      "dify_app_code": "ami-reperfusion-hint",
      "timeout_ms": 8000,
      "retry_count": 1,
      "required_inputs": [
        "patient_id",
        "encounter_id"
      ],
      "input_mappings": {
        "patient_id": "patient_context.patient.patient_id",
        "encounter_id": "patient_context.encounter.encounter_id",
        "current_node_code": "pathway.current_node_code"
      },
      "input_defaults": {
        "scenario": "PATHWAY_REPERFUSION",
        "language": "zh-CN"
      },
      "degraded_outputs": {
        "explanation": "Dify 不可用：再灌注策略请遵循专科共识与溶栓禁忌证清单。",
        "recommended_action": "尽快上级医师确认再灌注策略，并完成出血风险评估。"
      }
    }
  ]
}
