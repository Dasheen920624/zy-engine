{
  "dataset_id": "ERROR-SCENARIOS-001",
  "description": "异常和边界条件测试数据",
  "category": "edge-cases",
  "version": "1.0.0",
  "records": [
    {
      "id": "ERR-001",
      "scenario": "空诊断码",
      "input": { "diagnosis_code": "", "patient_id": "P-EMPTY-001" },
      "expected_result": "VALIDATION_ERROR",
      "expected_http_status": 400
    },
    {
      "id": "ERR-002",
      "scenario": "无效认证令牌",
      "input": { "token": "invalid-token-12345" },
      "expected_result": "AUTH_INVALID",
      "expected_http_status": 401
    },
    {
      "id": "ERR-003",
      "scenario": "跨租户访问",
      "input": { "tenant_id": 999, "target_tenant_id": 1 },
      "expected_result": "FORBIDDEN",
      "expected_http_status": 403
    },
    {
      "id": "ERR-004",
      "scenario": "超长字段输入",
      "input": { "display_name": "" },
      "expected_result": "VALIDATION_ERROR",
      "expected_http_status": 400
    },
    {
      "id": "ERR-005",
      "scenario": "并发重复提交",
      "input": { "concurrent_requests": 5, "idempotency_key": "DUP-001" },
      "expected_result": "CONFLICT or SUCCESS (idempotent)",
      "expected_http_status": [200, 409]
    }
  ]
}
