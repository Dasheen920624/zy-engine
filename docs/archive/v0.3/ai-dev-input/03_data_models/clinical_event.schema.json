{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "clinical_event.schema.json",
  "title": "ClinicalEvent",
  "type": "object",
  "required": ["event_id", "event_type", "event_time", "tenant_id", "org_code", "patient_id", "encounter_id", "source_system", "payload"],
  "properties": {
    "event_id": {"type": "string"},
    "event_type": {
      "type": "string",
      "enum": ["REGISTRATION_CREATED", "TRIAGE_UPDATED", "DOCUMENT_CREATED", "DOCUMENT_SUBMITTED", "LAB_RESULTED", "EXAM_RESULTED", "ORDER_CREATED", "DIAGNOSIS_UPDATED", "DISCHARGE_READY", "FOLLOWUP_RESULTED", "BATCH_QC"]
    },
    "event_time": {"type": "string", "format": "date-time"},
    "tenant_id": {"type": "string"},
    "org_code": {"type": "string"},
    "patient_id": {"type": "string"},
    "encounter_id": {"type": "string"},
    "visit_type": {"type": "string", "enum": ["OUTPATIENT", "EMERGENCY", "INPATIENT", "FOLLOWUP"]},
    "source_system": {"type": "string"},
    "source_event_id": {"type": "string"},
    "trace_id": {"type": "string"},
    "payload": {"type": "object", "additionalProperties": true}
  },
  "additionalProperties": false
}

