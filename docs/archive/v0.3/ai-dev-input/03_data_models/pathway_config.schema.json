{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pathway_config.schema.json",
  "title": "PathwayConfig",
  "type": "object",
  "required": ["pathway_code", "pathway_name", "version", "specialty_code", "entry_policy", "stages"],
  "properties": {
    "pathway_code": {"type": "string"},
    "pathway_name": {"type": "string"},
    "version": {"type": "string"},
    "specialty_code": {"type": "string"},
    "entry_policy": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {"type": "string", "enum": ["AUTO", "DOCTOR_CONFIRM", "MANUAL"]},
        "candidate_score_threshold": {"type": "number", "minimum": 0, "maximum": 100},
        "entry_rules": {"type": "array", "items": {"type": "string"}},
        "graph_query": {"type": "string"},
        "dify_workflow": {"type": "string"}
      },
      "additionalProperties": false
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["stage_code", "stage_name", "nodes"],
        "properties": {
          "stage_code": {"type": "string"},
          "stage_name": {"type": "string"},
          "sort_no": {"type": "integer"},
          "nodes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["node_code", "node_name", "node_type"],
              "properties": {
                "node_code": {"type": "string"},
                "node_name": {"type": "string"},
                "node_type": {"type": "string"},
                "entry_condition": {"type": "object", "additionalProperties": true},
                "exit_condition": {"type": "object", "additionalProperties": true},
                "sla_minutes": {"type": "integer"},
                "tasks": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
                "bindings": {"type": "object", "additionalProperties": true},
                "transitions": {"type": "array", "items": {"type": "object", "additionalProperties": true}}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

