# Oracle validation environment template.
# Copy this file to .env.oracle.local in the repository root and fill the local password.
# The real .env.oracle.local file is intentionally ignored and must not be committed.

$env:MEDKERNEL_DB_CONNECT='//192.168.4.25:1521/ORCL'
$env:MEDKERNEL_DB_URL='jdbc:oracle:thin:@//192.168.4.25:1521/ORCL'
$env:MEDKERNEL_DB_USERNAME='MEDKERNEL'
$env:MEDKERNEL_DB_PASSWORD='<local-password>'
